# Backend environment variables
# Copy this file to backend/.env and fill in the values.

NODE_ENV=development
FASTAPI_BASE_URL=http://localhost:8000
INTERNAL_API_SECRET=

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/baas_platform
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/baas_platform

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=baas_platform

REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT="s3.us-west-002.backblazeb2.com"
MINIO_PUBLIC_ENDPOINT="https://s3.us-west-002.backblazeb2.com"
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
REGION="us-west-002"
MINIO_USE_SSL=true

JWT_SECRET=
STAFF_JWT_SECRET=
STAFF_JWT_EXPIRY=28800
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

API_KEY_ENCRYPTION_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

OPENAI_API_KEY=
